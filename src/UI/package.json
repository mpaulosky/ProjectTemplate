{
	"name": "ui-tailwind",
	"private": true,
	"version": "1.0.0",
	"description": "Tailwind CSS build tooling for the UI Blazor Server project. Not published.",
	"scripts": {
		"build": "tailwindcss -i ./Styles/app.tailwind.css -o ./wwwroot/css/app.css",
		"build:release": "tailwindcss -i ./Styles/app.tailwind.css -o ./wwwroot/css/app.css --minify",
		"watch": "tailwindcss -i ./Styles/app.tailwind.css -o ./wwwroot/css/app.css --watch"
	},
	"devDependencies": {
		"@tailwindcss/cli": "^4.1.0",
		"tailwindcss": "^4.1.0"
	},
	"engines": {
		"node": ">=20"
	}
}
