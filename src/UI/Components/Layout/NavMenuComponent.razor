@implements IDisposable

@inject NavigationManager Navigation

<header role="banner" class="bg-primary-400 dark:bg-primary-400 border-b-2 border-primary-800 w-full py-2">
	<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 flex items-center justify-between">

		<a href="/" class="text-xl whitespace-nowrap font-bold">@_siteName</a>

		<nav aria-label="Main navigation" class="hidden md:flex items-center gap-1">
			@* <AuthorizeView> *@
			@* 	<Authorized> *@
					<a href="/dashboard"
						 class="px-3 py-2 rounded hover:bg-primary-100 hover:text-primary-700 transition-colors">Dashboard</a>
					<a href="/issues"
						 class="px-3 py-2 rounded hover:bg-primary-100 hover:text-primary-700 transition-colors">Issues</a>
					<a href="/issues/create"
						 class="px-3 py-2 rounded hover:bg-primary-100 hover:text-primary-700 transition-colors">Create</a>
			@* 	</Authorized> *@
			@* </AuthorizeView> *@

			@* <AuthorizeView Policy="@AuthorizationPolicies.AdminPolicy"> *@
			@* 	<Authorized> *@
			@* 		<div class="h-6 w-px bg-neutral-300 dark:bg-neutral-600 mx-2" aria-hidden="true"></div> *@
			@* 		<a href="/admin" *@
			@* 			 class="px-3 py-2 rounded hover:bg-primary-100 hover:text-primary-700 transition-colors">Admin Portal</a> *@
			@* 	</Authorized> *@
			@* </AuthorizeView> *@
		</nav>

		<div class="flex items-center gap-2">
			<button class="md:hidden p-2 rounded hover:bg-primary-100 hover:text-primary-700 transition-colors"
					aria-label="Toggle menu"
					aria-expanded="@(_mobileMenuOpen ? "true" : "false")"
					@onclick="() => { _mobileMenuOpen = !_mobileMenuOpen; }">
				@if (_mobileMenuOpen)
				{
					<span aria-hidden="true">✕</span>
				}
				else
				{
					<span aria-hidden="true">☰</span>
				}
			</button>
			@* <LoginDisplay /> *@
			@* <ThemeBrightnessToggleComponent /> *@
			@* <ThemeColorDropdownComponent /> *@
			@* <AuthorizeView> *@
			@* 	<Authorized> *@
			@* 		<SignalRConnection /> *@
			@* 	</Authorized> *@
			@* </AuthorizeView> *@
		</div>

	</div>

	@if (_mobileMenuOpen)
	{
		<nav aria-label="Mobile navigation" class="md:hidden border-t border-primary-800 py-2">
			@* <AuthorizeView> *@
			@* 	<Authorized> *@
					<a href="/dashboard" @onclick="() => _mobileMenuOpen = false"
					   class="block px-4 py-2 hover:bg-primary-100 hover:text-primary-700 transition-colors">Dashboard</a>
					<a href="/issues" @onclick="() => _mobileMenuOpen = false"
					   class="block px-4 py-2 hover:bg-primary-100 hover:text-primary-700 transition-colors">Issues</a>
					<a href="/issues/create" @onclick="() => _mobileMenuOpen = false"
					   class="block px-4 py-2 hover:bg-primary-100 hover:text-primary-700 transition-colors">Create</a>
			@* 	</Authorized> *@
			@* </AuthorizeView> *@
			@* <AuthorizeView Policy="@AuthorizationPolicies.AdminPolicy"> *@
			@* 	<Authorized> *@
			@* 		<a href="/admin" @onclick="() => _mobileMenuOpen = false" *@
			@* 		   class="block px-4 py-2 hover:bg-primary-100 hover:text-primary-700 transition-colors">Admin Portal</a> *@
			@* 	</Authorized> *@
			@* </AuthorizeView> *@
		</nav>
	}
</header>

@code {

	private bool _mobileMenuOpen;

	// [CascadingParameter] private Task<AuthenticationState>? AuthenticationState { get; set; }


	private const string _siteName = "ProjectName";

	protected override void OnInitialized()
	{
		Navigation.LocationChanged += OnLocationChanged;
	}

	private void OnLocationChanged(object? sender, LocationChangedEventArgs e)
	{
		if (_mobileMenuOpen)
		{
			_mobileMenuOpen = false;
			StateHasChanged();
		}
	}

	public void Dispose()
	{
		Navigation.LocationChanged -= OnLocationChanged;
	}

}
